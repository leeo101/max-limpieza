# Environment Variables
# Copy this file to .env.local and update the values

# WhatsApp number (with country code, no + or spaces)
# Example: 5491100000000 for Argentina
NEXT_PUBLIC_WHATSAPP_NUMBER=5491100000000

# JWT Secret (change this in production!)
JWT_SECRET=max-limpieza-secret-key-2024-change-in-production

# Node environment
NODE_ENV=development

# ===========================================
# EMAIL CONFIGURATION (SMTP)
# ===========================================
# For Gmail:
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Create an app password for "Mail"
# 3. Use that password below

# SMTP Host (for Gmail: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Your email address
SMTP_USER=your-email@gmail.com

# App password (NOT your regular password!)
# For Gmail: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password-here

# Admin email (where you'll receive order notifications)
ADMIN_EMAIL=your-email@gmail.com

# Site URL (for order links in emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
